# TropaSplit — Environment Variables 
# Copy frontend/.env.example to frontend/.env and fill in your values.

# The deployed Tropa Split Soroban contract address (from `stellar contract deploy`)
VITE_CONTRACT_ID=

# Soroban RPC endpoint
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443

# Network passphrase — must match the network you deployed to
VITE_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# USDC token or any other asset to split (Testnet USDC)
VITE_USDC_CONTRACT_ID=
